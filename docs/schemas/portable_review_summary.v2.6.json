{
  "contract": "portable_review_summary",
  "type_name": "PortableReviewSummary",
  "normalized_shape_version": "v2.6",
  "internal_schema_id": "stablenew.internal-review-summary.v2.6",
  "underlying_source_schema_examples": [
    "stablenew.internal-review-summary.v2.6",
    "stablenew.review.v2.6"
  ],
  "source_type_values": [
    "internal_learning_record",
    "embedded_review_metadata",
    "sidecar_review_metadata",
    "portable_review_metadata"
  ],
  "normalized_fields": [
    "source_type",
    "schema",
    "review_timestamp",
    "user_rating",
    "user_rating_raw",
    "quality_label",
    "subscores",
    "weighted_score",
    "user_notes",
    "prompt_before",
    "prompt_after",
    "negative_prompt_before",
    "negative_prompt_after",
    "prompt_delta",
    "negative_prompt_delta",
    "prompt_mode",
    "negative_prompt_mode",
    "stages",
    "review_context",
    "review_record_id"
  ],
  "normalization_rules": {
    "non_mapping_subscores_become_empty_object": true,
    "non_mapping_review_context_become_empty_object": true,
    "non_list_stages_become_empty_list": true,
    "missing_text_fields_become_empty_string": true,
    "missing_numeric_fields_may_be_null": true
  },
  "example_payload": {
