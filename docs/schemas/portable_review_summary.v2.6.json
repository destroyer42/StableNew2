    "schema": "stablenew.review.v2.6",
    "review_timestamp": "2026-03-23T12:00:00",
    "user_rating": 4,
    "user_rating_raw": 4,
    "quality_label": "good",
    "subscores": {
      "anatomy": 4,
      "composition": 5,
      "prompt_adherence": 4
    },
    "weighted_score": 4.4,
    "user_notes": "Strong prompt match.",
    "prompt_before": "portrait",
    "prompt_after": "portrait, dramatic light",
    "negative_prompt_before": "blurry",
    "negative_prompt_after": "blurry, extra limbs",
    "prompt_delta": ", dramatic light",
    "negative_prompt_delta": ", extra limbs",
    "prompt_mode": "append",
    "negative_prompt_mode": "append",
    "stages": [
      "img2img"
    ],
    "review_context": {
      "actor": "user"
    },
    "review_record_id": "review-run-1"
  }
}